{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Flutter debug",
            "type": "dart",
            "request": "launch",
            "program": "lib/buffer_stream/web_radio.dart",
            "flutterMode": "debug",
            // "env": {
            //     "NO_OPUS_OGG_LIBS": "1"
            // },
            "cwd": "${workspaceFolder}/example"
        },
        {
            "name": "Flutter profile",
            "type": "dart",
            "request": "launch",
            "program": "lib/mixing_bus/mixing_bus.dart",
            "flutterMode": "profile",
            // "env": {
            //     "NO_OPUS_OGG_LIBS": "1"
            // },
            "cwd": "${workspaceFolder}/example"
        },
        {
            "name": "Flutter release",
            "type": "dart",
            "request": "launch",
            "program": "lib/buffer_stream/web_radio.dart",
            "flutterMode": "release",
            // "env": {
            //     "NO_OPUS_OGG_LIBS": "1"
            // },
            "cwd": "${workspaceFolder}/example"
        },
        {
            "name": "Flutter test",
            "type": "dart",
            "request": "launch",
            "program": "tests/tests.dart",
            "flutterMode": "debug",
            "cwd": "${workspaceFolder}/example"
        },
        {
            "name": "Debug native Windows",
            "preLaunchTask": "compile windows debug",
            "type": "cppvsdbg",
            "request": "launch",
            "args": [],
            "program": "${workspaceFolder}/example/build/windows/x64/runner/Debug/flutter_soloud_example.exe",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Debug native Windows VERBOSE",
            "preLaunchTask": "compile windows debug verbose",
            "type": "cppvsdbg",
            "request": "launch",
            "args": [],
            "program": "${workspaceFolder}/example/build/windows/x64//runner/Debug/flutter_soloud_example.exe",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Debug native Linux",
            "preLaunchTask": "compile linux debug",
            "type": "cppdbg",
            "request": "launch",
            "args": [],
            "program": "${workspaceFolder}/example/build/linux/x64/debug/bundle/flutter_soloud_example",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Debug native Linux VERBOSE",
            "preLaunchTask": "compile linux debug verbose",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/example/build/linux/x64/debug/bundle/flutter_soloud_example",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Debug native Linux test",
            "preLaunchTask": "compile linux test debug",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/example/build/linux/x64/debug/bundle/flutter_soloud_example",
            "cwd": "${workspaceFolder}"
        },
        {
            // install CodeLLDB extension for macOS debugging
            // and remember to replace "-O2 -DNDEBUG" with "-O0 -g" in "target_compile_options" in "macos/CMakeLists.txt"
            "name": "Debug native macOS",
            "preLaunchTask": "compile macos debug",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/example/build/macos/Build/Products/Debug/flutter_soloud_example.app/Contents/MacOS/flutter_soloud_example",
            "cwd": "${workspaceFolder}",
            "sourceMap": {
                "${workspaceFolder}/example/macos/Flutter/ephemeral/.symlinks/plugins/flutter_soloud": "${workspaceFolder}"
            }
        },
        {
            "name": "Chrome wasm release",
            "type": "chrome",
            "preLaunchTask": "compile web wasm release",
            "request": "launch"
        }
    ]
}